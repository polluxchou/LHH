GEMINI_API_KEY=
DEEPSEEK_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
INGEST_SECRET=

# ── Account layer (Supabase Auth + multi-space) ───────────────
# Settings → API (NEXT_PUBLIC_* are exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Base URL used to build invite links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Settings → Database → Connection string (URI, includes password).
# Used only by local tooling (psql migrations / seed script), not the app runtime.
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres
